# Copy this file to .env.local and fill in real values. DO NOT commit .env.local to git.

# Stripe secret key (set this to your live or test key as appropriate)
STRIPE_SECRET_KEY=

# Stripe webhook signing secret (optional but recommended for verifying webhooks)
STRIPE_WEBHOOK_SECRET=

# NextAuth/APP URL used for success/cancel redirects
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=

# Google OAuth (create credentials in Google Cloud Console)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Optional email login provider (magic link)
# Preferred: Resend API (Vercel-friendly)
RESEND_API_KEY=
EMAIL_FROM="Konstbyte <no-reply@your-domain.se>"

# Optional SMTP fallback (only used when RESEND_API_KEY is empty)
EMAIL_SERVER=

# Hemsidor service - Email notifications for new leads
# Gmail SMTP (get app password from Google Account Security > App passwords)
EMAIL_USER=
EMAIL_PASSWORD=
