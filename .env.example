# Konstbyte environment variables example

# Postgres connection string
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require

# NextAuth
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=replace_with_a_strong_secret
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# Email login via Resend (recommended in production/Vercel)
RESEND_API_KEY=re_...
EMAIL_FROM="Konstbyte <no-reply@your-domain.se>"

# Optional SMTP fallback (used only if RESEND_API_KEY is not set)
EMAIL_SERVER=smtp://user:pass@smtp.mailtrap.io:587

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# UploadThing
UPLOADTHING_SECRET=your_uploadthing_secret
NEXT_PUBLIC_UPLOADTHING_ENDPOINT=https://uploadthing.example

# OpenAI
OPENAI_API_KEY=sk-...

# SEO & Metadata base URL (used for canonical URLs, JSON-LD, OG images)
NEXT_PUBLIC_METADATA_BASE=https://konstbyte.se

# Groq (used for AI art valuation vision model)
GROQ_API_KEY=gsk_...

# Other
NODE_ENV=development
