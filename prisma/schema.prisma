datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id               String            @id @default(cuid())
  name             String?
  email            String?           @unique
  emailVerified    DateTime?
  image                   String?
  createdAt               DateTime          @default(now())
  stripeAccountId         String?
  stripeOnboardingDone    Boolean           @default(false)
  accounts         Account[]
  sessions         Session[]
  artworks         Artwork[]         @relation("ArtworkOwner")
  favorites        Favorite[]
  orders           Order[]           @relation("OrderBuyer")
  soldOrders       Order[]           @relation("OrderSeller")
  posts            Post[]
  comments         Comment[]
  notifications    Notification[]
  following        Follow[]          @relation("Follower")
  followers        Follow[]          @relation("Following")
  artValuationLogs     ArtValuationLog[]
  challengeSubmissions ChallengeSubmission[]
  challengeLikes       ChallengeLike[]
  challengePoints      ChallengePoints?
  sentMessages         Message[]             @relation("MessageSender")
  receivedMessages     Message[]             @relation("MessageRecipient")
  postReactions        PostReaction[]
  payouts              Payout[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Artwork {
  id              String     @id @default(cuid())
  title           String
  imageUrl        String
  description     String?
  price           Float      @default(0)
  category        String     @default("malningar")
  isPublished     Boolean    @default(true)
  isSold          Boolean    @default(false)
  soldAt          DateTime?
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
  ownerId         String
  // Shipping settings — set by seller per artwork
  shippingType    String     @default("overenskommes")
  // "overenskommes" | "fixed" | "pickup" | "postnord" | "dhl" | "schenker" | "other"
  shippingCost    Float?     // SEK, only used when shippingType = "fixed"
  shippingArea    String?    // city/area, only used when shippingType = "pickup"
  shippingCarrier String?    // carrier name, only used when shippingType = "other"
  owner           User       @relation("ArtworkOwner", fields: [ownerId], references: [id])
  orders          Order[]
  favorites       Favorite[]
}

model Order {
  id        String       @id @default(cuid())
  buyerId   String
  sellerId  String?
  artworkId String
  amount    Float
  status               String       @default("pending")
  paymentMethod        String       @default("stripe")  // "stripe" | "swish"
  feeAmount            Float?
  stripeSessionId      String?
  swishPaymentId       String?
  sellerPayoutStatus   String       @default("unpaid")  // "unpaid" | "paid"
  sellerPayoutNote     String?
  sellerPayoutAt       DateTime?
  // Shipping fields — snapshot from artwork at purchase time
  shippingMethod       String?      // snapshot of artwork.shippingType
  shippingCost         Float        @default(0)
  shippingStatus       String       @default("not_shipped")
  // "not_shipped" | "shipped" | "delivered"
  trackingNumber       String?
  trackingUrl          String?
  // Buyer shipping address — collected in checkout modal
  shippingName         String?
  shippingStreet       String?
  shippingPostalCode   String?
  shippingCity         String?
  shippingCountry      String?
  shippingPhone        String?
  createdAt            DateTime     @default(now())
  buyer     User         @relation("OrderBuyer", fields: [buyerId], references: [id])
  seller    User?        @relation("OrderSeller", fields: [sellerId], references: [id])
  artwork   Artwork      @relation(fields: [artworkId], references: [id])
  payments  Payment[]
  items     OrderItem[]
  events    OrderEvent[]
  payout    Payout?

  @@index([sellerId, status])
  @@index([sellerId, shippingStatus])
  @@index([buyerId, status])
}

model OrderItem {
  id       String @id @default(cuid())
  orderId  String
  title    String
  price    Float
  imageUrl String
  order    Order  @relation(fields: [orderId], references: [id])
}

model OrderEvent {
  id        String   @id @default(cuid())
  orderId   String
  type      String
  message   String
  createdAt DateTime @default(now())
  order     Order    @relation(fields: [orderId], references: [id])
}

model Payment {
  id       String @id @default(cuid())
  orderId  String
  stripeId String @unique
  amount   Float
  order    Order  @relation(fields: [orderId], references: [id])
}

model Favorite {
  id        String   @id @default(cuid())
  userId    String
  artworkId String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
  artwork   Artwork  @relation(fields: [artworkId], references: [id])

  @@unique([userId, artworkId])
}

model Post {
  id        String         @id @default(cuid())
  content   String
  imageUrl  String?
  likes     Int            @default(0)
  authorId  String
  createdAt DateTime       @default(now())
  author    User           @relation(fields: [authorId], references: [id])
  comments  Comment[]
  reactions PostReaction[]
}

model PostReaction {
  id        String   @id @default(cuid())
  postId    String
  userId    String
  type      String   // "like" | "heart" | "wow"
  createdAt DateTime @default(now())
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id])

  @@unique([postId, userId])
}

model Comment {
  id        String   @id @default(cuid())
  content   String
  postId    String
  authorId  String
  createdAt DateTime @default(now())
  post      Post     @relation(fields: [postId], references: [id])
  author    User     @relation(fields: [authorId], references: [id])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  type      String
  message   String
  link      String?
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
}

model Follow {
  id          String   @id @default(cuid())
  followerId  String
  followingId String
  createdAt   DateTime @default(now())
  follower    User     @relation("Follower", fields: [followerId], references: [id])
  following   User     @relation("Following", fields: [followingId], references: [id])

  @@unique([followerId, followingId])
}

model Message {
  id          String   @id @default(cuid())
  senderId    String
  recipientId String
  content     String
  read        Boolean  @default(false)
  createdAt   DateTime @default(now())
  sender      User     @relation("MessageSender", fields: [senderId], references: [id])
  recipient   User     @relation("MessageRecipient", fields: [recipientId], references: [id])
}

model ArtValuationLog {
  id        String   @id @default(cuid())
  userId    String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
}

model Testimonial {
  id        String   @id @default(cuid())
  text      String
  author    String
  createdAt DateTime @default(now())
}

model Challenge {
  id          String                @id @default(cuid())
  title       String
  description String
  themePrompt String
  imageUrl    String?
  weekNumber  Int
  year        Int
  startsAt    DateTime
  endsAt      DateTime
  createdAt   DateTime              @default(now())
  submissions ChallengeSubmission[]

  @@unique([weekNumber, year])
}

model ChallengeSubmission {
  id          String          @id @default(cuid())
  challengeId String
  artistId    String
  title       String
  description String?
  imageUrl    String
  price       Float?
  createdAt   DateTime        @default(now())
  challenge   Challenge       @relation(fields: [challengeId], references: [id])
  artist      User            @relation(fields: [artistId], references: [id])
  likes       ChallengeLike[]
}

model ChallengeLike {
  id           String              @id @default(cuid())
  submissionId String
  userId       String
  createdAt    DateTime            @default(now())
  submission   ChallengeSubmission @relation(fields: [submissionId], references: [id])
  user         User                @relation(fields: [userId], references: [id])

  @@unique([submissionId, userId])
}

model ChallengePoints {
  id        String   @id @default(cuid())
  userId    String   @unique
  points    Int      @default(0)
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id])
}

model Payout {
  id                 String    @id @default(cuid())
  sellerId           String
  orderId            String    @unique
  amount             Float
  commissionRate     Float
  commissionAmount   Float
  commissionVat      Float
  sellerPayoutAmount Float
  method             String    @default("swish") // "bank" | "swish"
  status             String    @default("pending") // "pending" | "completed"
  adminNote          String?
  createdAt          DateTime  @default(now())
  completedAt        DateTime?
  seller             User      @relation(fields: [sellerId], references: [id])
  order              Order     @relation(fields: [orderId], references: [id])
}
